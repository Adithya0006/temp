from sqlalchemy import and_

@app.delete("/inventory/equipments/{stage_id}/{eqpt_no}")
def delete_equipment(stage_id: int, eqpt_no: str, db: Session = Depends(init_db)):
    # Filter by both parameters to ensure precision
    eq = db.query(Equipments).filter(
        and_(
            Equipments.stage_id == stage_id,
            Equipments.eqpt_no == eqpt_no
        )
    ).first()

    if not eq:
        raise HTTPException(
            status_code=404, 
            detail=f"Equipment {eqpt_no} not found at Stage {stage_id}"
        )

    db.delete(eq)
    db.commit()
    return {"message": f"Equipment {eqpt_no} deleted from Stage {stage_id} successfully"}

