@app.get("/inventory/equipments", response_model=List[EquipmentSchema])
def get_all_equipments(db: Session = Depends(init_db)):
    # .order_by() sorts the results by stage_id numerically (1, 2, 3...)
    items = db.query(Equipments).order_by(Equipments.stage_id.asc()).all()
    return items

@app.post("/inventory/equipments")
def add_equipment(data: EquipmentCreate, db: Session = Depends(init_db)):
    new_eq = Equipments(**data.model_dump()) # model_dump() replaces .dict() in Pydantic V2
    db.add(new_eq)
    db.commit()
    db.refresh(new_eq)
    return {"message": "Equipment added successfully", "id": new_eq.id}

@app.put("/inventory/equipments/{eq_id}")
def update_equipment(eq_id: int, data: EquipmentSchema, db: Session = Depends(init_db)):
    eq = db.query(Equipments).filter(Equipments.id == eq_id).first()
    if not eq:
        raise HTTPException(status_code=404, detail="Equipment not found")
    for key, value in data.dict().items():
        setattr(eq, key, value)
    db.commit()
    return {"message": "Equipment updated"}

