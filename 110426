


from fastapi import APIRouter, UploadFile, File, Form, HTTPException, Depends
from sqlalchemy.orm import Session
from datetime import datetime
from pydantic import BaseModel
from typing import List, Optional

# --- Pydantic Schemas for Request Validation ---
class FormFieldSchema(BaseModel):
    label: str
    type: str  # text, number, date, boolean, file
    required: bool
    min_limit: Optional[float] = None
    max_limit: Optional[float] = None

class WorkflowStepSchema(BaseModel):
    stage_id: int
    step_sequence: int
    form_schema: List[FormFieldSchema]

class FullProductTemplateRequest(BaseModel):
    part_number: str
    product_type_name: str
    sub_product_type_name: Optional[str] = None
    workflow_steps: List[WorkflowStepSchema]

# --- UPDATED POST ENDPOINT ---
@app.post("/api/forms/save-template")
async def save_form_template(payload: FullProductTemplateRequest, db: Session = Depends(init_db)):
    """
    Saves/Updates Product Master, its specific Workflow Sequence, 
    and the Dynamic Form Schemas for every stage in that sequence.
    """
    try:
        # 1. Update or Create the Product Master entry
        product = db.query(ProductTypeMaster).filter(
            ProductTypeMaster.part_number == payload.part_number
        ).first()

        if not product:
            product = ProductTypeMaster(
                part_number=payload.part_number,
                product_type_name=payload.product_type_name,
                sub_product_type_name=payload.sub_product_type_name
            )
            db.add(product)
        else:
            product.product_type_name = payload.product_type_name
            product.sub_product_type_name = payload.sub_product_type_name
        
        db.flush() # Secure the part_number for foreign keys

        # 2. Sync Workflow Mapping & Form Templates
        # We clear existing mappings for this product to prevent sequence conflicts
        db.query(ProductWorkflowMapping).filter(
            ProductWorkflowMapping.product_type_id == payload.part_number
        ).delete()

        for step in payload.workflow_steps:
            # A. Create Workflow Sequence Link
            new_mapping = ProductWorkflowMapping(
                product_type_id=payload.part_number,
                flow_step_id=step.stage_id,
                step_sequence=step.step_sequence
            )
            db.add(new_mapping)

            # B. Update/Create Dynamic Form for this Stage + Product
            # We filter by both stage_id and product_type to allow different forms for the same stage
            existing_form = db.query(DynamicFormTemplate).filter(
                DynamicFormTemplate.stage_id == step.stage_id,
                DynamicFormTemplate.product_type == payload.part_number
            ).first()

            # Convert Pydantic list of fields to a serializable dictionary for JSON column
            serialized_schema = [field.dict() for field in step.form_schema]

            if existing_form:
                existing_form.form_schema = serialized_schema
                existing_form.updated_at = datetime.now()
            else:
                new_form = DynamicFormTemplate(
                    stage_id=step.stage_id,
                    product_type=payload.part_number, # Linked to our ProductMaster
                    form_schema=serialized_schema,
                    is_active=True,
                    created_at=datetime.now()
                )
                db.add(new_form)

        # 3. Finalize all changes
        db.commit()
        return {
            "status": "success", 
            "message": f"Template and Workflow for {payload.part_number} saved successfully."
        }

    except Exception as e:
        db.rollback()
        raise HTTPException(status_code=500, detail=f"Database error during save: {str(e)}")


# --- UPDATED GET CONFIG ENDPOINT ---
@app.get("/get-form-config/{part_number}/{stage_id}")
async def get_form_config(part_number: str, stage_id: int, db: Session = Depends(init_db)):
    """
    Fetches the specific dynamic form schema for a Part Number at a specific Stage.
    This allows the Operator Dashboard to be truly product-specific.
    """
    # 1. Verify this stage is actually part of this product's assigned workflow
    workflow_check = db.query(ProductWorkflowMapping).filter(
        ProductWorkflowMapping.product_type_id == part_number,
        ProductWorkflowMapping.flow_step_id == stage_id
    ).first()

    if not workflow_check:
        raise HTTPException(
            status_code=400, 
            detail=f"Stage {stage_id} is not part of the defined workflow for Part {part_number}."
        )

    # 2. Fetch the specific form template
    template = db.query(DynamicFormTemplate).filter(
        DynamicFormTemplate.stage_id == stage_id,
        DynamicFormTemplate.product_type == part_number,
        DynamicFormTemplate.is_active == True
    ).first()

    if not template:
        raise HTTPException(
            status_code=404, 
            detail=f"No form schema defined for Part {part_number} at Stage {stage_id}."
        )

    return {
        "part_number": part_number,
        "stage_id": template.stage_id,
        "sequence": workflow_check.step_sequence,
        "form_schema": template.form_schema
    }


# --- UPDATED LIST ENDPOINT ---
@app.get("/api/forms/list-templates")
async def list_all_templates(db: Session = Depends(init_db)):
    """
    Returns a comprehensive list of Products and their configured stages.
    """
    products = db.query(ProductTypeMaster).all()
    
    results = []
    for p in products:
        # Get count of configured stages for this product
        stage_count = db.query(ProductWorkflowMapping).filter(
            ProductWorkflowMapping.product_type_id == p.part_number
        ).count()

        results.append({
            "part_number": p.part_number,
            "product_name": p.product_type_name,
            "sub_type": p.sub_product_type_name,
            "total_stages": stage_count
        })

    return results












