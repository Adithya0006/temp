```python
@app.post("/mrlrevalidationdocsupload")
async def upload_file(
    operatorid: str = Form(...), 
    stage_id: int = Form(...),    # Identifying which stage this document belongs to
    file: UploadFile = File(...),
    db: Session = Depends(init_db)
):
    """
    Uploads a PDF revalidation document and links it to a specific operator slot.
    """
    
    # 1. Validation
    if not operatorid or operatorid.lower() in ["null", "undefined"]:
        raise HTTPException(status_code=400, detail="A valid Operator ID is required.")

    if not file.filename.lower().endswith('.pdf'):
        raise HTTPException(status_code=400, detail="Only PDF files are allowed.")

    # 2. Manage existing files for this operator
    # Note: If you want to store documents per-stage, update filter to include stage_id
    existing_doc = db.query(MRLRevalidationDocs).filter(
        MRLRevalidationDocs.operatorid == operatorid
    ).first()

    action = "UPLOAD"

    if existing_doc:
        action = "REPLACE"
        if existing_doc.file_path and os.path.exists(existing_doc.file_path):
            try:
                os.remove(existing_doc.file_path)
            except OSError:
                pass
        db.delete(existing_doc)
        db.commit()

    # 3. Save the new PDF to local storage
    timestamp = datetime.now().strftime("%Y%m%d%H%M%S")
    safe_filename = f"{timestamp}_{file.filename.replace(' ', '_')}"
    
    os.makedirs(UPLOAD_DIR, exist_ok=True)
    file_path = os.path.join(UPLOAD_DIR, safe_filename)

    with open(file_path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)

    # 4. Save Metadata & Log for the specific renewal action
    new_doc = MRLRevalidationDocs(
        operatorid=operatorid,
        filename=safe_filename,
        original_filename=file.filename,
        file_path=file_path
    )
    
    log_entry = MRLRevalidationDocsLog(
        action_type=action,
        file_name=file.filename,
        operatorid=operatorid 
        # Optional: Add stage_id to your Log model if needed for history tracking
    )
    
    db.add(new_doc)
    db.add(log_entry)
    db.commit()
    db.refresh(new_doc)
    
    return {
        "status": "success", 
        "operatorid": operatorid, 
        "stage_id": stage_id,
        "document": new_doc.original_filename
    }

```

### Behavior Summary

* **Targeted Updates:** If you have 10 rows for "Operator Ravi," only the specific row matching the `stage_id` provided will be updated.
* **Independence:** An operator can now have different expiry dates for different skills (e.g., Printer might expire in `0127` while AOI expires in `0628`).
* **Safety:** If the `stage_id` does not match the `operatorid` in the database, the system will return a `404 Error` rather than incorrectly updating the wrong record.

